{
  "version": 2,
  "builds": [
    {
      "src": "jss_archive/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/staticfiles/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/jss_archive/wsgi.py"
    }
  ]
}
